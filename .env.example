# ── 필수 ───────────────────────────────
# Anthropic API 키 (서버 전용, 절대 클라이언트 노출 금지)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# 사용할 모델 (선택, 기본값 claude-sonnet-5)
DIAGNOSE_MODEL=claude-sonnet-5

# ── 리드 저장 (선택) ────────────────────
# 미설정 시 이메일이 있어도 저장만 스킵, 진단은 정상 동작
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── 리포트 이메일 (선택, Resend) ────────
# 미설정 시 이메일 발송 스킵
RESEND_API_KEY=re_xxxxxxxx
# 발신 주소 (Resend에서 kitt.ai.kr 도메인 인증 후 설정 / 미설정 시 테스트용 onboarding@resend.dev)
EMAIL_FROM=Kitt AI <noreply@kitt.ai.kr>
# 관리자 알림 수신 주소
EMAIL_ADMIN=partner@kitt.ai.kr

# ── 관리자 대시보드 (/admin) ────────────
# 둘 다 설정해야 /admin 접근 가능 (미설정 시 503)
ADMIN_USER=admin
ADMIN_PASS=change-this-strong-password
